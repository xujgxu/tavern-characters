{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "世界": {
      "type": "object",
      "properties": {
        "时间": {
          "type": "string"
        },
        "地点": {
          "default": "西部住宅区_绿洲景苑小区-6幢601",
          "type": "string"
        }
      },
      "required": [
        "时间"
      ]
    },
    "主角": {
      "type": "object",
      "properties": {
        "饱食度": {
          "type": "number"
        },
        "精神值": {
          "type": "number"
        },
        "金钱": {
          "default": 1800,
          "type": "number"
        },
        "心情值": {
          "default": 0,
          "type": "number"
        },
        "性欲值": {
          "default": 0,
          "type": "number"
        },
        "快感值": {
          "default": 0,
          "type": "number"
        },
        "整体色情值": {
          "default": 0,
          "type": "number"
        }
      },
      "required": [
        "饱食度",
        "精神值"
      ]
    },
    "APP": {
      "type": "object",
      "properties": {
        "等级": {
          "default": 1,
          "type": "number"
        },
        "经验值": {
          "default": 0,
          "type": "number"
        },
        "已完成任务数": {
          "default": 0,
          "type": "number"
        },
        "本周已完成": {
          "default": false,
          "type": "boolean"
        },
        "当前任务": {
          "default": null,
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "名称": {
                  "type": "string"
                },
                "类型": {
                  "type": "string"
                },
                "等级": {
                  "type": "number"
                },
                "色情维度": {
                  "type": "number"
                },
                "社会维度": {
                  "type": "number"
                },
                "内容": {
                  "type": "string"
                },
                "报酬": {
                  "type": "number"
                },
                "可选挑战": {
                  "type": "string"
                },
                "状态": {
                  "default": "进行中",
                  "type": "string"
                }
              },
              "required": [
                "名称",
                "类型",
                "等级",
                "色情维度",
                "社会维度",
                "内容",
                "报酬",
                "可选挑战"
              ]
            },
            {
              "type": "null"
            }
          ]
        },
        "待选任务": {
          "default": [],
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "名称": {
                "type": "string"
              },
              "类型": {
                "type": "string"
              },
              "等级": {
                "type": "number"
              },
              "色情维度": {
                "type": "number"
              },
              "社会维度": {
                "type": "number"
              },
              "内容": {
                "type": "string"
              },
              "报酬": {
                "type": "number"
              },
              "可选挑战": {
                "type": "string"
              }
            },
            "required": [
              "名称",
              "类型",
              "等级",
              "色情维度",
              "社会维度",
              "内容",
              "报酬",
              "可选挑战"
            ]
          }
        }
      }
    },
    "联系人": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "好感度": {
            "type": "number"
          },
          "身份": {
            "type": "string"
          },
          "消息": {
            "default": [],
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "发送方": {
                  "type": "string"
                },
                "内容": {
                  "type": "string"
                },
                "时间": {
                  "type": "string"
                }
              },
              "required": [
                "发送方",
                "内容",
                "时间"
              ]
            }
          }
        },
        "required": [
          "好感度",
          "身份"
        ]
      }
    }
  },
  "required": [
    "世界",
    "主角",
    "APP"
  ]
}