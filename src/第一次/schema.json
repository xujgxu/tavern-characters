{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "世界": {
      "type": "object",
      "properties": {
        "时间": {
          "type": "string"
        },
        "地点": {
          "default": "",
          "type": "string"
        }
      },
      "required": [
        "时间"
      ]
    },
    "主角": {
      "type": "object",
      "properties": {
        "饱食度": {
          "type": "number"
        },
        "精神值": {
          "type": "number"
        },
        "金钱": {
          "type": "number"
        },
        "心情值": {
          "type": "number"
        },
        "性欲值": {
          "type": "number"
        },
        "快感值": {
          "type": "number"
        },
        "整体色情值": {
          "type": "number"
        }
      },
      "required": [
        "饱食度",
        "精神值",
        "金钱",
        "心情值",
        "性欲值",
        "快感值",
        "整体色情值"
      ]
    }
  },
  "required": [
    "世界",
    "主角"
  ]
}